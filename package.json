{
  "name": "pg-simple-migrate",
  "version": "1.0.0",
  "description": "Simple, standalone PostgreSQL migration tool with zero dependencies (except pg)",
  "main": "migrate.js",
  "bin": {
    "pg-migrate": "./migrate.js"
  },
  "scripts": {
    "migrate": "node migrate.js up",
    "migrate:status": "node migrate.js status",
    "migrate:down": "node migrate.js down",
    "migrate:create": "node migrate.js create"
  },
  "keywords": [
    "postgresql",
    "postgres",
    "pg",
    "migration",
    "migrations",
    "database",
    "schema",
    "migrate"
  ],
  "author": "Jonathan Ross",
  "license": "MIT",
  "dependencies": {
    "pg": "^8.11.3"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jonathan-ross/pg-simple-migrate.git"
  }
}
